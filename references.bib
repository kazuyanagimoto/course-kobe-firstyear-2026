@article{hamermesh1994,
  title = {Beauty and the {{Labor Market}}},
  author = {Hamermesh, Daniel S. and Biddle, Jeff E.},
  year = 1994,
  journal = {The American Economic Review},
  volume = {84},
  number = {5},
  eprint = {2117767},
  eprinttype = {jstor},
  pages = {1174--1194},
  publisher = {American Economic Association},
  issn = {00028282},
  urldate = {2026-03-31},
  abstract = {We examine the impact of looks on earnings using interviewers' ratings of respondents' physical appearance. Plain people earn less than average-looking people, who earn less than the good-looking. The plainness penalty is 5-10 percent, slightly larger than the beauty premium. Effects for men are at least as great as for women. Unattractive women have lower labor-force participation rates and marry men with less human capital. Better-looking people sort into occupations where beauty may be more productive; but the impact of individuals' looks is mostly independent of occupation, suggesting the existence of pure employer discrimination.},
  file = {/Users/kazuharu/Zotero/storage/NSZV3P5I/Hamermesh と Biddle - Beauty and the Labor Market.pdf}
}

@article{hitsch2010,
  title = {Matching and {{Sorting}} in {{Online Dating}}},
  author = {Hitsch, Gunter J. and Horta{\c c}su, Ali and Ariely, Dan},
  year = 2010,
  month = mar,
  journal = {American Economic Review},
  volume = {100},
  number = {1},
  pages = {130--163},
  issn = {0002-8282},
  doi = {10.1257/aer.100.1.130},
  urldate = {2026-03-23},
  abstract = {Using data on user attributes and interactions from an online dating site, we estimate mate preferences, and use the Gale-Shapley algorithm to predict stable matches. The predicted matches are similar to the actual matches achieved by the dating site, and the actual matches are approximately efficient. Out-of- sample predictions of offline matches, i.e., marriages, exhibit assortative mating patterns similar to those observed in actual marriages. Thus, mate preferences, without resort to search frictions, can generate sorting in marriages. However, we underpredict some of the correlation patterns; search frictions may play a role in explaining the discrepancy. (JEL C78, J12)},
  langid = {english},
  keywords = {Bargaining Theory,Bargaining Theory; Matching Theory,Domestic Abuse,Family Structure,Marital Dissolution,Marriage; Marital Dissolution; Family Structure; Domestic Abuse,Matching Theory Marriage},
  file = {/Users/kazuharu/Zotero/storage/8HVU67RD/Hitsch et al. - 2010 - Matching and Sorting in Online Dating.pdf}
}

